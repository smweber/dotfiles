# Brewfile - cross-platform Homebrew packages (macOS + Linux/linuxbrew)
#
# Install with: brew bundle --file Brewfile
# `brew bundle` is idempotent - safe to re-run any time.
#
# macOS-only packages and casks live in Brewfile.macos.

# GNU Stow 2.4+ (apt's version is too old for --dotfiles --no-folding)
brew "stow"

# Shell / terminal core
brew "fish"
brew "tmux"
brew "neovim"

# Dev tooling
brew "mise"       # runtime version manager
brew "jj"         # jujutsu VCS
brew "gh"         # GitHub CLI (used by bootstrap for SSH key upload)
brew "fzf"
brew "ripgrep"
brew "bat"
brew "direnv"

# CLI utilities
brew "btop"
brew "tree"
brew "jq"
